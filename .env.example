# Copy this file to .env and fill in real values locally.
# Do not commit your real .env file.

SERPAPI_KEY=

OPENAI_API_KEY=

# Only needed if you flip use_deepseek_for_dossier or
# use_deepseek_for_campaign to true in configs/app.toml.
# See docs/intelligence-providers.md for the switch guide.
DEEPSEEK_API_KEY=

REDIS_URL=redis://localhost:6379

# Comma-separated list of allowed CORS origins for the API.
# Default (if unset): http://localhost:3000,http://127.0.0.1:3000
# In production, set to your deployed web origin, e.g.
#   WEB_ORIGIN=https://prospero.barclay-simpson.com
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000

# ─── Outreach tracking (open + click pixels) ───────────────────────
# Master kill switch for the injection + link-rewrite path. When set
# to false the /t/* endpoints still exist but new outbound mail is
# sent with the original body unchanged. Default: true.
OUTREACH_TRACKING_ENABLED=true

# Base URL prepended when injecting tracking links into outbound mail.
# Locally: http://localhost:8000 — recipients can only fetch the pixel
# from your machine, so real-inbox tracking won't work until deployed.
# Tunneling tools (ngrok, Cloudflare Tunnel) make localhost reachable
# during testing if you want real-inbox tracking before deploy.
# In prod this becomes the BS-owned tracking subdomain
# (e.g. https://link.barclaysimpson.com).
TRACKING_DOMAIN=http://localhost:8000

# HMAC secret for signing tracking tokens. MUST be set in any
# non-dry-run / shared environment — using the in-code default in
# production would let anyone forge open/click events. 32+ random
# bytes (base64 or hex) is fine; rotated alongside the Graph secret.
PROSPERO_TRACKING_SECRET=

# Where /t/c/<token> redirects when the click token is unforgeable
# (corruption / forgery / very old link). Defaults to barclaysimpson.com
# if unset.
# TRACKING_FALLBACK_URL=https://www.barclaysimpson.com
