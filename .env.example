# Copy this file to .env and fill in real values locally.
# Do not commit your real .env file.

SERPAPI_KEY=

OPENAI_API_KEY=

# Only needed if you flip use_deepseek_for_dossier or
# use_deepseek_for_campaign to true in configs/app.toml.
# See docs/intelligence-providers.md for the switch guide.
DEEPSEEK_API_KEY=

REDIS_URL=redis://localhost:6379

# Comma-separated list of allowed CORS origins for the API.
# Default (if unset): http://localhost:3000,http://127.0.0.1:3000
# In production, set to your deployed web origin, e.g.
#   WEB_ORIGIN=https://prospero.barclay-simpson.com
WEB_ORIGIN=http://localhost:3000,http://127.0.0.1:3000
